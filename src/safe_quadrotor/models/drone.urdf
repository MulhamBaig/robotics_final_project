<?xml version="1.0"?>
<robot name="simple_drone">

  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.4 0.4 0.1"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.4 0.4 0.1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.5"/>
      <inertia ixx="0.021" ixy="0.0" ixz="0.0" iyy="0.021" iyz="0.0" izz="0.04"/>
    </inertial>
  </link>

  <link name="rotor_fl">
    <visual>
      <geometry>
        <cylinder radius="0.1" length="0.02"/>
      </geometry>
      <material name="red">
        <color rgba="1.0 0.0 0.0 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="joint_fl" type="fixed">
    <parent link="base_link"/>
    <child link="rotor_fl"/>
    <origin xyz="0.2 0.2 0.05" rpy="0 0 0"/>
  </joint>

  <link name="rotor_fr">
    <visual>
      <geometry>
        <cylinder radius="0.1" length="0.02"/>
      </geometry>
      <material name="red">
        <color rgba="1.0 0.0 0.0 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="joint_fr" type="fixed">
    <parent link="base_link"/>
    <child link="rotor_fr"/>
    <origin xyz="0.2 -0.2 0.05" rpy="0 0 0"/>
  </joint>

  <link name="rotor_bl">
    <visual>
      <geometry>
        <cylinder radius="0.1" length="0.02"/>
      </geometry>
      <material name="black">
        <color rgba="0.0 0.0 0.0 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="joint_bl" type="fixed">
    <parent link="base_link"/>
    <child link="rotor_bl"/>
    <origin xyz="-0.2 0.2 0.05" rpy="0 0 0"/>
  </joint>

  <link name="rotor_br">
    <visual>
      <geometry>
        <cylinder radius="0.1" length="0.02"/>
      </geometry>
      <material name="black">
        <color rgba="0.0 0.0 0.0 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="joint_br" type="fixed">
    <parent link="base_link"/>
    <child link="rotor_br"/>
    <origin xyz="-0.2 -0.2 0.05" rpy="0 0 0"/>
  </joint>

  <gazebo reference="base_link">
    <sensor name="gpu_lidar" type="gpu_lidar">
      <pose>0 0 0.1 0 0 0</pose>
      <topic>/scan</topic>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.141592</min_angle>
            <max_angle>3.141592</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.15</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <always_on>1</always_on>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <gazebo>
    <plugin filename="gz-sim-velocity-control-system" name="gz::sim::systems::VelocityControl">
      <link_name>base_link</link_name>
    </plugin>
    <plugin filename="gz-sim-odometry-publisher-system" name="gz::sim::systems::OdometryPublisher">
      <odom_topic>model/simple_drone/odometry</odom_topic>
      <dimensions>3</dimensions>
    </plugin>
  </gazebo>

</robot>